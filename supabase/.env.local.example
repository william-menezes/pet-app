# supabase/.env.local.example
# Template de variáveis de ambiente locais — NÃO contém segredos reais.
# Copie para supabase/.env.local e preencha com os valores locais.
# O arquivo .env.local está no .gitignore; NUNCA commite o .env.local real.

# Segredos das Edge Functions (usados por `supabase functions serve`)
GOOGLE_OAUTH_CLIENT_ID=your-google-client-id-here
GOOGLE_OAUTH_SECRET=your-google-client-secret-here

# Salt para hash de e-mail/IP em auth_login_attempts e auth_audit_log.
# Em produção: use `supabase secrets set HASH_SALT=<valor-aleatorio-forte>`
HASH_SALT=local-dev-salt-replace-in-production

# Chave do serviço (gerada automaticamente pelo `supabase start`; NÃO commitar).
# Disponível em: supabase status -> service_role key
SUPABASE_SERVICE_ROLE_KEY=

# URL local do Supabase (gerada pelo `supabase start`)
SUPABASE_URL=http://localhost:54321
